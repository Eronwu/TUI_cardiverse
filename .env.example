# Copy this file to .env and fill in only the providers you use.
# The real .env file is intentionally ignored by git.

# OpenAI-compatible LLM provider config. Prefer these for third-party providers
# such as agnes-ai if they expose an OpenAI-compatible Responses API.
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME=
# auto | responses | chat_completions
LLM_API_STYLE=auto
LLM_TIMEOUT_SECONDS=25

# Native OpenAI fallback config.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=

# Optional local model endpoint.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# Optional default compiler settings.
CARDIVERSE_COMPILER_MODE=stub
CARDIVERSE_LLM_PROVIDER=
