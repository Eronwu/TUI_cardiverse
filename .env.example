# Copy this file to .env and fill in only the providers you use.
# The real .env file is intentionally ignored by git.

# Optional cloud model providers for future LLM compiler support.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional local model endpoint.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# Optional default compiler settings.
CARDIVERSE_COMPILER_MODE=stub
CARDIVERSE_LLM_PROVIDER=
