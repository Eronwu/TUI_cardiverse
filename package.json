{
  "name": "terminal-cardiverse",
  "version": "0.1.0",
  "description": "A terminal-native prompt-compiled card strategy game.",
  "type": "module",
  "bin": {
    "cardiverse": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "PRD.md",
    "TECH_DESIGN.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
